# >>> cc-select shell integration (managed by cc-select; do not edit between markers) >>>
# ccs 是 cc-select 的短别名：use 走 eval 注入当前 shell，其余子命令直接转发。
ccs() {
  if [ "$#" -gt 0 ] && [ "$1" = "use" ]; then
    eval "$("{{.BinaryPath}}" use "${@:2}")"
  else
    "{{.BinaryPath}}" "$@"
  fi
}
# <<< cc-select shell integration <<<
